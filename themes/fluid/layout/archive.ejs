<%
page.layout = "archive"
page.title = theme.archive.title || __('archive.title')
page.subtitle = theme.archive.subtitle || __('archive.subtitle')
page.banner_img = theme.archive.banner_img
page.banner_img_height = theme.archive.banner_img_height
page.banner_mask_alpha = theme.archive.banner_mask_alpha
%>

<div class="archive-wrapper">
    <!-- 粒子背景 -->
    <div class="particles-container" id="particles-container"></div>
    
    <!-- 搜索和筛选区域 -->
    <div class="archive-header">
        <div class="header-content">
            <div class="title-section">
                <h1 class="archive-title">
                    <span class="title-icon">
                        <i class="fas fa-archive"></i>
                    </span>
                    Archive
                </h1>
                <p class="archive-subtitle">
                    <%= site.posts.length %> 篇文章
                </p>
            </div>
            
            <div class="search-wrapper">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input 
                        type="text" 
                        id="search-input" 
                        placeholder="搜索文章..." 
                        class="search-input"
                    >
                    <button id="search-clear" class="search-clear" style="display: none;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>
        
        <!-- 分类标签 -->
        <div class="filter-tabs">
            <div class="tabs-wrapper">
                <button 
                    class="tab-btn active" 
                    data-filter="all"
                >
                    <i class="fas fa-layer-group"></i>
                    全部
                </button>
                <% site.categories.each(function (category) { %>
                    <button 
                        class="tab-btn" 
                        data-filter="category-<%= category.name %>"
                    >
                        <i class="fas fa-folder"></i>
                        <%= category.name %>
                    </button>
                <% }) %>
            </div>
        </div>
        
        <!-- 年份导航 -->
        <div class="year-nav">
            <div class="year-label">按年份浏览</div>
            <div class="year-timeline">
                <div class="timeline-line"></div>
                <div class="year-dots">
                    <% var years = [] %>
                    <% page.posts.each(function (post) { %>
                        <% var year = date(post.date, "YYYY") %>
                        <% if (years.indexOf(year) === -1) { %>
                            <% years.push(year) %>
                            <button 
                                class="year-dot" 
                                data-year="<%= year %>"
                            >
                                <span class="year-number"><%= year %></span>
                                <span class="year-pulse"></span>
                            </button>
                        <% } %>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 视图切换 -->
    <div class="view-controls">
        <button 
            id="view-timeline" 
            class="view-btn active" 
            title="时间线视图"
        >
            <i class="fas fa-list view-icon"></i>
            <span class="view-label">时间线</span>
        </button>
        <button 
            id="view-grid" 
            class="view-btn" 
            title="网格视图"
        >
            <i class="fas fa-th view-icon"></i>
            <span class="view-label">网格</span>
        </button>
    </div>
    
    <!-- 文章列表区域 -->
    <div class="archive-content">
        <%- partial('_partials/archive-posts.ejs') %>
    </div>
    
    <!-- 返回顶部按钮 -->
    <button id="back-to-top" class="back-to-top" style="display: none;" aria-label="返回顶部">
        <i class="fas fa-arrow-up"></i>
        <span class="back-to-top-label">TOP</span>
    </button>
</div>

<!-- 引入归档页面专用脚本 -->
<script src="<%= url_for('/js/archive.js') %>"></script>
