$primary-color = #0A84FF
$accent-color = #30D158
$warning-color = #FFD60A
$purple-color = #BF5AF2

.archive-wrapper
    position relative
    padding 1rem 0 2rem 0
    width 100%

.particles-container
    position fixed
    top 0
    left 0
    width 100%
    height 100vh
    pointer-events none
    z-index 0
    overflow hidden

.particle
    position absolute
    width 4px
    height 4px
    background rgba(255, 255, 255, 0.1)
    border-radius 50%
    animation float 15s ease-in-out infinite

@keyframes float
    0%, 100%
        transform translateY(0) translateX(0)
        opacity 0.3
    50%
        transform translateY(-50px) translateX(20px)
        opacity 0.6

.archive-header
    position relative
    z-index 10
    margin-bottom 2rem

.header-content
    display flex
    justify-content space-between
    align-items flex-start
    flex-wrap wrap
    gap 1.5rem

.title-section
    .archive-title
        font-size 2.5rem
        font-weight 800
        color var(--text-color)
        display flex
        align-items center
        gap 1rem
        margin 0
        .title-icon
            width 50px
            height 50px
            background linear-gradient(135deg, $primary-color, $accent-color)
            border-radius 12px
            display flex
            align-items center
            justify-content center
            font-size 1.25rem
            box-shadow 0 0 30px rgba($primary-color, 0.3)
    .archive-subtitle
        color var(--sec-text-color)
        font-size 1rem
        margin 0.5rem 0 0 0
        font-weight 400

.search-wrapper
    flex-shrink 0
    width 100%
    max-width 350px

.search-box
    position relative
    display flex
    align-items center
    background var(--board-bg-color)
    backdrop-filter blur(20px)
    border 1px solid var(--line-color)
    border-radius 12px
    padding 0.75rem 1rem

.search-icon
    color var(--sec-text-color)
    font-size 1rem
    margin-right 0.5rem

.search-input
    flex 1
    background transparent
    border none
    outline none
    color var(--text-color)
    font-size 0.95rem
    ::placeholder
        color var(--sec-text-color)

.search-clear
    background none
    border none
    color var(--sec-text-color)
    cursor pointer
    padding 0.25rem
    transition color 0.3s
    &:hover
        color var(--text-color)

.filter-tabs
    margin-top 1.5rem
    overflow-x auto

.tabs-wrapper
    display flex
    gap 0.75rem
    padding 0.25rem 0
    scrollbar-width none
    &::-webkit-scrollbar
        display none

.tab-btn
    display flex
    align-items center
    gap 0.4rem
    padding 0.6rem 1.25rem
    background var(--board-bg-color)
    backdrop-filter blur(10px)
    border 1px solid var(--line-color)
    border-radius 20px
    color var(--sec-text-color)
    font-size 0.85rem
    cursor pointer
    transition all 0.3s
    white-space nowrap
    &:hover
        border-color rgba(255, 255, 255, 0.3)
        color var(--text-color)
    &.active
        background linear-gradient(135deg, rgba($accent-color, 0.2), rgba($primary-color, 0.2))
        border-color $accent-color
        color $accent-color
        box-shadow 0 0 20px rgba($accent-color, 0.2)

.year-nav
    margin-top 1.5rem
    padding 1.25rem
    background var(--board-bg-color)
    backdrop-filter blur(15px)
    border-radius 16px
    border 1px solid var(--line-color)

.year-label
    color var(--sec-text-color)
    font-size 0.8rem
    font-weight 600
    text-transform uppercase
    letter-spacing 1.5px
    margin-bottom 1rem

.year-timeline
    position relative
    padding 1rem 0

.timeline-line
    position absolute
    top 50%
    left 0
    right 0
    height 2px
    background linear-gradient(90deg, transparent, rgba($accent-color, 0.4), transparent)
    transform translateY(-50%)

.year-dots
    display flex
    justify-content space-around
    position relative
    z-index 1

.year-dot
    position relative
    width 40px
    height 40px
    border-radius 50%
    background var(--board-bg-color)
    border 2px solid rgba(255, 255, 255, 0.15)
    display flex
    align-items center
    justify-content center
    cursor pointer
    transition all 0.3s
    overflow hidden
    .year-number
        color var(--sec-text-color)
        font-size 0.75rem
        font-weight 600
        transition color 0.3s
    .year-pulse
        position absolute
        width 100%
        height 100%
        border-radius 50%
        background radial-gradient(circle, rgba($accent-color, 0.35) 0%, transparent 70%)
        opacity 0
        transform scale(0)
        transition all 0.3s
    &:hover
        border-color $accent-color
        transform scale(1.1)
        .year-number
            color var(--text-color)
        .year-pulse
            opacity 1
            transform scale(1)
    &.active
        border-color $accent-color
        background rgba($accent-color, 0.12)
        .year-number
            color $accent-color
        .year-pulse
            opacity 1
            transform scale(1)

.view-controls
    position fixed
    top 50%
    right 1.5rem
    transform translateY(-50%)
    display flex
    flex-direction column
    gap 0.5rem
    z-index 100
    background var(--board-bg-color)
    backdrop-filter blur(15px)
    border 1px solid var(--line-color)
    border-radius 14px
    padding 0.5rem
    box-shadow 0 8px 32px rgba(0, 0, 0, 0.2)

.view-btn
    width 48px
    height 48px
    background transparent
    border none
    border-radius 10px
    color var(--sec-text-color)
    cursor pointer
    transition all 0.3s
    display flex
    flex-direction column
    align-items center
    justify-content center
    gap 0.15rem
    &:hover
        background rgba(255, 255, 255, 0.05)
        color var(--text-color)
    &.active
        background linear-gradient(135deg, rgba($primary-color, 0.2), rgba($accent-color, 0.2))
        color $accent-color
    .view-icon
        font-size 1rem
    .view-label
        font-size 0.6rem
        font-weight 500

.archive-content
    position relative
    z-index 10
    width 100%
    padding 1.5rem 0 3rem 0

.archive-list
    display flex
    flex-direction column
    gap 3rem

.year-group
    margin-bottom 1rem
    .year-header
        display flex
        align-items center
        gap 1rem
        margin-bottom 1.5rem
        .year-title
            font-size 1.5rem
            font-weight 700
            color var(--text-color)
            margin 0
        .year-divider
            flex 1
            height 2px
            background linear-gradient(90deg, rgba($accent-color, 0.5), transparent)
        .year-count
            color var(--sec-text-color)
            font-size 0.85rem
            font-weight 500

.post-cards
    display grid
    grid-template-columns repeat(auto-fill, minmax(300px, 1fr))
    gap 1.75rem
    width 100%

.post-card
    position relative
    background var(--board-bg-color)
    backdrop-filter blur(20px)
    border 1px solid var(--line-color)
    border-radius 16px
    padding 1.5rem
    cursor pointer
    transition all 0.35s ease
    overflow hidden
    &::before
        content ''
        position absolute
        top 0
        left 0
        right 0
        height 3px
        background linear-gradient(90deg, $primary-color, $accent-color)
        transform scaleX(0)
        transition transform 0.35s ease
        transform-origin left
    &:hover
        transform translateY(-8px)
        border-color rgba(255, 255, 255, 0.25)
        box-shadow 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba($accent-color, 0.1)
        &::before
            transform scaleX(1)
    &.hidden
        display none

.card-header
    display flex
    justify-content space-between
    align-items flex-start
    margin-bottom 0.875rem

.card-category
    display inline-flex
    align-items center
    gap 0.25rem
    padding 0.25rem 0.625rem
    background rgba($primary-color, 0.12)
    border-radius 6px
    color $primary-color
    font-size 0.7rem
    font-weight 600

.card-date
    color var(--sec-text-color)
    font-size 0.8rem
    font-family 'JetBrains Mono', monospace

.card-title
    font-size 1.1rem
    font-weight 600
    color var(--text-color)
    margin 0 0 0.75rem 0
    line-height 1.4
    transition color 0.3s
    &:hover
        color $accent-color

.card-excerpt
    color var(--sec-text-color)
    font-size 0.85rem
    line-height 1.6
    margin 0 0 0.875rem 0
    display -webkit-box
    -webkit-line-clamp 2
    -webkit-box-orient vertical
    overflow hidden

.card-footer
    display flex
    justify-content space-between
    align-items center
    padding-top 0.875rem
    border-top 1px solid var(--line-color)

.card-tags
    display flex
    flex-wrap wrap
    gap 0.4rem
    .tag
        padding 0.15rem 0.4rem
        background rgba(255, 255, 255, 0.04)
        border-radius 4px
        color var(--sec-text-color)
        font-size 0.7rem
        display flex
        align-items center
        gap 0.15rem

.card-readtime
    display flex
    align-items center
    gap 0.3rem
    color var(--sec-text-color)
    font-size 0.75rem

.empty-state
    text-align center
    padding 4rem 1.5rem
    .empty-icon
        font-size 4rem
        color var(--line-color)
        margin-bottom 1.25rem
    .empty-text
        color var(--sec-text-color)
        font-size 1.1rem

.back-to-top
    position fixed
    bottom 2rem
    right 2rem
    width 60px
    height 60px
    background var(--board-bg-color)
    backdrop-filter blur(15px)
    border 2px solid var(--line-color)
    border-radius 50%
    color var(--text-color)
    cursor pointer
    transition all 0.35s
    display flex
    flex-direction column
    align-items center
    justify-content center
    gap 0.15rem
    z-index 100
    box-shadow 0 4px 20px rgba(0, 0, 0, 0.3)
    &:hover
        background rgba($accent-color, 0.15)
        border-color $accent-color
        transform translateY(-4px) scale(1.05)
        box-shadow 0 8px 30px rgba($accent-color, 0.2)
    i
        font-size 1.1rem
        color $accent-color
    .back-to-top-label
        font-size 0.6rem
        font-weight 700
        color $accent-color
        letter-spacing 0.5px

@media (max-width: 992px)
    .header-content
        flex-direction column
        align-items stretch
    .title-section
        text-align center
        .archive-title
            justify-content center
    .search-wrapper
        max-width 100%
    .view-controls
        top auto
        bottom 1.5rem
        right auto
        left 50%
        transform translateX(-50%)
        flex-direction row
        gap 0.4rem
        padding 0.4rem
    .post-cards
        grid-template-columns repeat(auto-fill, minmax(280px, 1fr))
        gap 1.5rem
    .archive-list
        gap 2.5rem
    .archive-content
        padding 1rem 0 2.5rem 0
    .back-to-top
        width 54px
        height 54px
        bottom 1.5rem
        right 1.5rem
        i
            font-size 1rem
        .back-to-top-label
            font-size 0.55rem

@media (max-width: 576px)
    .archive-wrapper
        padding 0.75rem 0 2rem 0
    .title-section
        .archive-title
            font-size 2rem
            .title-icon
                width 42px
                height 42px
                font-size 1.1rem
    .year-nav
        padding 1rem
    .year-dot
        width 32px
        height 32px
        .year-number
            font-size 0.65rem
    .post-cards
        grid-template-columns 1fr
        gap 1.25rem
    .archive-list
        gap 2rem
    .archive-content
        padding 0.75rem 0 2rem 0
    .post-card
        padding 1.25rem
    .view-controls
        gap 0.3rem
        .view-btn
            width 44px
            height 44px
            .view-label
                display none
    .back-to-top
        width 50px
        height 50px
        bottom 1rem
        right 1rem
        .back-to-top-label
            display none

.archive-content.grid-view
    .post-cards
        grid-template-columns repeat(auto-fill, minmax(280px, 1fr))
        gap 1.5rem

.archive-content.timeline-view
    .year-group
        margin-bottom 2.5rem
    .post-cards
        grid-template-columns 1fr

// 在归档页面隐藏主题自带的返回顶部按钮，使用自定义按钮
.archive-wrapper ~ #scroll-top-button
    display none !important
